# Clé API Brevo (PAS la clé SMTP !) → Paramètres → SMTP & API → Clés API → Créer une clé API
# Doit commencer par xkeysib- (pas xsmtpsib-)
BREVO_API_KEY=xkeysib-xxxxxxxx

# Expéditeur SMS (max 11 caractères, validé dans Brevo → SMS → Expéditeurs)
BREVO_SMS_SENDER=CLab

# Numéro qui reçoit les réservations (format international sans +)
BREVO_SMS_RECIPIENT=33637160713

# Code page admin (petit bouton · en bas du site)
ADMIN_PASSWORD=change-me
